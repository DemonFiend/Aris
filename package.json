{
  "name": "aris",
  "version": "0.1.0",
  "private": true,
  "description": "AI gaming companion — expressive, private, model-agnostic",
  "author": "Aris Team",
  "license": "Unlicense",
  "scripts": {
    "dev": "pnpm --filter @aris/shared build && pnpm --filter @aris/avatar build && (pnpm --filter @aris/renderer dev & pnpm --filter @aris/app dev)",
    "build": "pnpm -r build",
    "build:app": "pnpm build && electron-builder",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "clean": "pnpm -r exec rm -rf dist && rm -rf release"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/node": "^22.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "electron-builder-squirrel-windows": "^26.8.1",
    "eslint": "^9.0.0",
    "playwright": "^1.58.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
