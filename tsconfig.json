{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@aris/*": ["packages/*/src"]
    }
  },
  "exclude": ["node_modules", "dist", "release"],
  "references": [
    { "path": "packages/shared" },
    { "path": "packages/ai-core" },
    { "path": "packages/vision" },
    { "path": "packages/voice" },
    { "path": "packages/avatar" },
    { "path": "packages/app" },
    { "path": "packages/renderer" }
  ]
}
